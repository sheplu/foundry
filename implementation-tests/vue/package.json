{
  "name": "@foundry/vue-canary",
  "version": "0.0.0",
  "private": true,
  "description": "Vue 3.5 canary app consuming built @foundry/* packages per AGENTS.md §9.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "node scripts/generate-vue-types.ts && vite",
    "build": "node scripts/generate-vue-types.ts && vite build",
    "preview": "vite preview",
    "typecheck": "node scripts/check-vue-types.ts && vue-tsc --noEmit",
    "generate:types": "node scripts/generate-vue-types.ts"
  },
  "dependencies": {
    "@foundry/elements": "*",
    "@foundry/icons": "*",
    "@foundry/themes": "*",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vue-tsc": "^3.2.7"
  }
}
