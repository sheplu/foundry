{
  "name": "@foundry/html-js-canary",
  "version": "0.0.0",
  "private": true,
  "description": "Plain HTML + ES-module canary app consuming built @foundry/* packages per AGENTS.md §9. No bundler.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "node scripts/generate-html-data.ts && http-server ../.. -p 5175 -a 127.0.0.1 -c-1 --silent",
    "start": "node scripts/generate-html-data.ts && http-server ../.. -p 5175 -a 127.0.0.1 -c-1 --silent",
    "typecheck": "node scripts/check-html-data.ts",
    "generate:types": "node scripts/generate-html-data.ts"
  },
  "dependencies": {
    "@foundry/elements": "*",
    "@foundry/icons": "*",
    "@foundry/themes": "*"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
