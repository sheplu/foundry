{
  "name": "foundry",
  "version": "0.0.0",
  "private": true,
  "description": "Web Component based Atomic Design System",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test:unit": "vitest run --passWithNoTests",
    "test:functional": "echo 'test:functional not yet wired' && exit 0",
    "test:visual": "echo 'test:visual not yet wired' && exit 0",
    "test:e2e": "echo 'test:e2e not yet wired' && exit 0",
    "test": "npm run typecheck && npm run lint && npm run test:unit && npm run test:functional && npm run test:visual && npm run test:e2e",
    "coverage": "vitest run --coverage --passWithNoTests",
    "storybook": "echo 'storybook not yet wired' && exit 0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
