{
  "name": "foundry",
  "version": "0.0.0",
  "private": true,
  "description": "Web Component based Atomic Design System",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "implementation-tests/*",
    "implementation-tests/e2e/*"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "npm run build -w @foundry/tokens -w @foundry/elements -w @foundry/icons -w @foundry/themes -w @foundry/storybook -w @foundry/react-canary --if-present",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test:unit": "vitest run --passWithNoTests",
    "test:functional": "npm run test:functional -w @foundry/elements",
    "test:visual": "npm run test -w @foundry/visual-tests",
    "test:visual:update": "npm run test:update -w @foundry/visual-tests",
    "test:e2e": "npm run test -w @foundry/functional-tests",
    "dev:react": "npm run dev -w @foundry/react-canary",
    "test": "npm run typecheck && npm run lint && npm run test:unit && npm run test:functional && npm run test:visual && npm run test:e2e",
    "coverage": "vitest run --coverage --passWithNoTests",
    "storybook": "npm run storybook -w @foundry/storybook",
    "build-storybook": "npm run build -w @foundry/storybook"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
