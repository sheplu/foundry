{
  "name": "@foundry/elements",
  "version": "0.0.0",
  "description": "Foundry web components built on native custom elements.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "custom-elements.json"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.template.html"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -b",
    "test:unit": "vitest run --passWithNoTests",
    "test:functional": "web-test-runner --config web-test-runner.config.js"
  },
  "dependencies": {
    "@foundry/tokens": "*"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "axe-core": "^4.11.3"
  }
}
