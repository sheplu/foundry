{
  "name": "@foundry/tokens",
  "version": "0.0.0",
  "description": "Design tokens — source-of-truth TS, plus emitted JS, JSON, and CSS artifacts.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.json": "./dist/tokens.json",
    "./css/primitive.css": "./dist/css/primitive.css",
    "./css/semantic.css": "./dist/css/semantic.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && node scripts/build-artifacts.ts",
    "typecheck": "tsc -b",
    "test:unit": "vitest run --passWithNoTests"
  }
}
