{
  "name": "@foundry/themes",
  "version": "0.0.0",
  "description": "Token value-sets compiled to CSS, including the default theme.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    "./css/default.css": "./dist/css/default.css",
    "./css/dark.css": "./dist/css/dark.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build-artifacts.ts",
    "typecheck": "tsc -b",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@foundry/tokens": "*"
  }
}
