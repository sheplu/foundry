{
  "name": "@foundry/themes",
  "version": "0.0.0",
  "description": "Token value-sets compiled to CSS, including the default theme.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -b",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@foundry/tokens": "*"
  }
}
